{
  "name": "n8n-nodes-syphoon",
  "version": "1.0.0",
  "description": "n8n community node for Syphoon — Amazon product scraping and price intelligence API",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "syphoon",
    "amazon",
    "price-monitoring",
    "price-intelligence",
    "ecommerce",
    "scraping",
    "asin",
    "competitor-tracking"
  ],
  "license": "MIT",
  "homepage": "https://syphoon.com",
  "author": {
    "name": "Vigasini",
    "email": "vigasinimit@gmail.com",
    "url": "https://github.com/vigasinii"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vigasinii/n8n-nodes-syphoon"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier src --write",
    "lint": "eslint nodes credentials --ext .ts",
    "lintfix": "eslint nodes credentials --ext .ts --fix",
    "prepublishOnly": "npm run build && npm run lint",
    "test": "jest"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SyphoonApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Syphoon/Syphoon.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^18.16.0",
    "@typescript-eslint/parser": "^5.60.0",
    "eslint-plugin-n8n-nodes-base": "^1.13.1",
    "gulp": "^4.0.2",
    "n8n-workflow": "^2.13.0",
    "prettier": "^2.8.8",
    "typescript": "^5.1.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
